#!/bin/bash
# git-branch-clean — prune stale remote refs and delete obsolete local branches
#
# Runs git fetch --prune, then deletes:
#   1. local branches whose upstream is gone (": gone]" in git branch -vv), and
#   2. local branches with no upstream that are fully merged into the integration
#      branch (resolved from origin/HEAD).
#
# Usage:
#   git-branch-clean [-h|--help]
#
# Example:
#   $ git-branch-clean
#   Fetching and pruning...
#   Deleted branch feature/login (was abc1234).
#   Deleted branch fix/typo (was def5678).
#   No stale branches to clean up.

_print_help() {
  awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

case "$1" in
  -h|--help) _print_help; exit 0 ;;
esac

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "fatal: not a git repository"
  exit 1
fi

echo "Fetching and pruning..."
git fetch --prune || { echo "fatal: failed to fetch from origin"; exit 1; }

main_ref=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
if [ -z "$main_ref" ]; then
  echo "fatal: cannot determine origin/HEAD (try: git remote set-head origin -a)"
  exit 1
fi
main_branch=${main_ref#origin/}

gone=$(git branch -vv | awk '/: gone]/{print ($1 == "*" ? $2 : $1)}')

untracked_merged=$(
  git for-each-ref --format='%(refname:short) %(upstream)' refs/heads/ \
    | awk '$2 == "" {print $1}' \
    | while IFS= read -r b; do
        [ "$b" = "$main_branch" ] && continue
        if git merge-base --is-ancestor "$b" "$main_ref"; then
          echo "$b"
        fi
      done
)

to_delete=$(printf '%s\n%s\n' "$gone" "$untracked_merged" | awk 'NF && !seen[$0]++')

if [ -z "$to_delete" ]; then
  echo "No stale branches to clean up."
  exit 0
fi

while IFS= read -r branch; do
  git branch -D "$branch"
done <<< "$to_delete"
