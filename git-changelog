#!/bin/bash
# git-changelog — draft the next CHANGELOG entry and version bump using Claude
#
# Collects the commits and diff since the last release tag, sends them to Claude
# together with the previous version, and asks it to draft the next "Keep a
# Changelog" entry and to suggest the next version bump — patch or minor, never
# major (major releases are cut manually). Opens your editor pre-filled with the
# proposed entry so you can confirm, choose, or edit it, then inserts it at the
# top of CHANGELOG.md.
#
# By default both committed changes since the baseline AND the current
# uncommitted (staged + unstaged) changes and untracked files are considered —
# handy when you prepare the CHANGELOG.md edit together with the changes it
# describes, in a single commit. Use --committed-only to restrict to changes
# that are already committed.
#
# The proposed entry is opened in your editor BEFORE CHANGELOG.md is touched, so
# you can confirm, reword, or change the version. The version (and therefore the
# patch-vs-minor bump) is taken from the "## [x.y.z] - date" header line you save,
# so you can override Claude's suggestion just by editing that number.
#
# With --release it also commits CHANGELOG.md, creates the release tag, and
# pushes the commit and tag to origin. When uncommitted changes are included
# (the default), the release commit bundles all your working-tree changes
# together with the CHANGELOG.md update, and its message is generated by the
# sibling git-commit-msg helper (opens an editor to confirm); with
# --committed-only it is a CHANGELOG-only commit messaged "Release <version>".
# Use --message to set the commit message explicitly (and non-interactively).
#
# Usage:
#   git-changelog [options]
#
# Options:
#   -r, --release        Commit CHANGELOG.md, create the release tag, and push both
#       --no-push        With --release, commit and tag locally but do not push
#       --committed-only Ignore uncommitted changes; use only committed changes
#   -m, --message <msg>  Use <msg> as the release commit message (skips generation)
#       --no-diff        Send only commit messages + diffstat to Claude (skip full diff)
#   -y, --yes            Skip the confirmation prompt before releasing
#       --from <ref>     Use <ref> as the previous release instead of the latest tag
#   -f, --file <path>    Changelog file to update (default: CHANGELOG.md in repo root)
#   -h, --help           Show this help message
#
# Examples:
#   git-changelog                    # draft from committed + uncommitted changes, edit, insert
#   git-changelog --committed-only   # consider only already-committed changes
#   git-changelog --release          # bundle changes + CHANGELOG, commit (git-commit-msg), tag, push
#   git-changelog -r -m "Add X"      # bundled release with an explicit commit message
#   git-changelog --committed-only -r  # CHANGELOG-only release commit, tag, push
#   git-changelog --from v3.12.0     # baseline against v3.12.0 instead of latest tag
#
# Requirements:
#   git, claude (Claude CLI — https://claude.ai/code)
#   git-commit-msg (optional sibling script) — generates bundled release commit messages

_print_help() {
  awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

RELEASE=0
PUSH=1
INCLUDE_DIFF=1
ASSUME_YES=0
WORKING=1
FROM_TAG=""
CHANGELOG_FILE=""
COMMIT_MSG=""

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) _print_help; exit 0 ;;
    -r|--release) RELEASE=1 ;;
    --no-push) PUSH=0 ;;
    --no-diff) INCLUDE_DIFF=0 ;;
    -y|--yes) ASSUME_YES=1 ;;
    -w|--working) WORKING=1 ;;
    --committed-only|--no-working) WORKING=0 ;;
    -m|--message) shift; COMMIT_MSG="$1" ;;
    --message=*) COMMIT_MSG="${1#*=}" ;;
    --from) shift; FROM_TAG="$1" ;;
    --from=*) FROM_TAG="${1#*=}" ;;
    -f|--file) shift; CHANGELOG_FILE="$1" ;;
    --file=*) CHANGELOG_FILE="${1#*=}" ;;
    *) echo "fatal: unknown option: $1"; exit 1 ;;
  esac
  shift
done

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "fatal: not a git repository"
  exit 1
fi

if ! command -v claude > /dev/null 2>&1; then
  echo "fatal: claude CLI not found"
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
[ -z "$CHANGELOG_FILE" ] && CHANGELOG_FILE="$REPO_ROOT/CHANGELOG.md"

# Locate the sibling git-commit-msg helper — used to author a descriptive commit
# message when a release bundles real code changes (not just the changelog).
GIT_COMMIT_MSG=""
if command -v git-commit-msg > /dev/null 2>&1; then
  GIT_COMMIT_MSG="git-commit-msg"
else
  _self_dir=$(cd "$(dirname "$0")" && pwd 2>/dev/null)
  [ -n "$_self_dir" ] && [ -x "$_self_dir/git-commit-msg" ] && GIT_COMMIT_MSG="$_self_dir/git-commit-msg"
fi

# --- Determine baseline (previous release) -----------------------------------

if [ -n "$FROM_TAG" ]; then
  PREV_REF="$FROM_TAG"
  if ! git rev-parse --verify --quiet "$PREV_REF" > /dev/null; then
    echo "fatal: --from ref not found: $PREV_REF"
    exit 1
  fi
else
  PREV_REF=$(git describe --tags --abbrev=0 2>/dev/null)
  if [ -z "$PREV_REF" ]; then
    echo "fatal: no tags found — pass --from <ref> to set the baseline"
    exit 1
  fi
fi

# Current version: parse from the baseline ref, else from the changelog top, else 0.0.0
CURRENT_VERSION=$(printf '%s' "$PREV_REF" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1)
if [ -z "$CURRENT_VERSION" ] && [ -f "$CHANGELOG_FILE" ]; then
  CURRENT_VERSION=$(grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' "$CHANGELOG_FILE" | head -1)
fi
[ -z "$CURRENT_VERSION" ] && CURRENT_VERSION="0.0.0"

# Tag prefix: mirror whatever the repo's existing version tags use (e.g. "v")
TAG_PREFIX=""
LATEST_TAG=$(git tag --sort=-v:refname 2>/dev/null | grep -E '^v?[0-9]+\.[0-9]+' | head -1)
case "$LATEST_TAG" in
  v[0-9]*) TAG_PREFIX="v" ;;
esac

# --- Ensure there is something to release ------------------------------------

COMMIT_COUNT=$(git rev-list --count "$PREV_REF..HEAD" 2>/dev/null)
COMMIT_COUNT=${COMMIT_COUNT:-0}

# Detect uncommitted work (tracked changes vs HEAD, plus untracked files)
HAS_UNCOMMITTED=0
if ! git diff --quiet HEAD 2>/dev/null || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  HAS_UNCOMMITTED=1
fi

# Diff spec: a single ref ("$PREV_REF") diffs the working tree against the tag
# (committed + uncommitted); the range form stops at HEAD (committed only).
if [ "$WORKING" -eq 1 ]; then
  DIFF_SPEC="$PREV_REF"
else
  DIFF_SPEC="$PREV_REF..HEAD"
fi

if [ "$WORKING" -eq 1 ]; then
  if [ "$COMMIT_COUNT" -eq 0 ] && [ "$HAS_UNCOMMITTED" -eq 0 ]; then
    echo "fatal: no committed or uncommitted changes since $PREV_REF — nothing to release"
    exit 1
  fi
  extra=""
  [ "$HAS_UNCOMMITTED" -eq 1 ] && extra=" + uncommitted working-tree changes"
  echo "Baseline: $PREV_REF (current version $CURRENT_VERSION), $COMMIT_COUNT commit(s) since$extra."
else
  if [ "$COMMIT_COUNT" -eq 0 ]; then
    echo "fatal: no commits since $PREV_REF — nothing to release"
    if [ "$HAS_UNCOMMITTED" -eq 1 ]; then
      echo "hint: you have uncommitted changes — drop --committed-only to include them"
    fi
    exit 1
  fi
  echo "Baseline: $PREV_REF (current version $CURRENT_VERSION), $COMMIT_COUNT commit(s) since (committed only)."
fi

# --- Gather context for Claude -----------------------------------------------

context=$(
  printf 'Previous released version: %s\n\n' "$CURRENT_VERSION"
  printf '=== Commits since %s ===\n' "$PREV_REF"
  git log --no-merges --pretty=format:'- %s%n%b' "$PREV_REF..HEAD"
  if [ "$WORKING" -eq 1 ] && [ "$HAS_UNCOMMITTED" -eq 1 ]; then
    printf '\n\n=== Uncommitted working-tree changes (NOT yet committed, part of this release) ===\n'
    git diff HEAD --stat
    untracked=$(git ls-files --others --exclude-standard)
    [ -n "$untracked" ] && printf '\nUntracked (new) files:\n%s\n' "$untracked"
  fi
  printf '\n\n=== Diffstat (all changes since %s) ===\n' "$PREV_REF"
  git diff --stat "$DIFF_SPEC"
  if [ "$INCLUDE_DIFF" -eq 1 ]; then
    printf '\n=== Full diff (all changes since %s) ===\n' "$PREV_REF"
    git diff "$DIFF_SPEC"
  fi
  if [ -f "$CHANGELOG_FILE" ]; then
    printf '\n=== Existing changelog (top, for style reference) ===\n'
    head -n 40 "$CHANGELOG_FILE"
  fi
)

prompt='You are drafting the next changelog entry for a project that follows the
"Keep a Changelog" format and Semantic Versioning. The input below contains the
previous released version, the commits and diff since that release, and the top
of the existing CHANGELOG for style reference.

Do two things:

1. Decide the next version bump. Output "patch" if the changes are only bug
   fixes or internal changes with no new functionality, or "minor" if there is
   any new feature or notable user-facing change. NEVER output "major" — major
   releases are cut manually.

2. Write the changelog entry body in Keep a Changelog style: group bullets under
   the relevant "### Added", "### Changed", "### Fixed", "### Removed" headings
   (include only the headings that have entries). Each bullet is one concise line
   describing a notable or user-facing change. Match the terse, descriptive tone
   of the existing changelog shown in the input. Omit pure internal refactors
   with no observable effect unless there is nothing else to report.

Output EXACTLY in this format and nothing else:
BUMP: <patch|minor>
REASON: <one short line explaining the bump choice>
---
### Added
- ...
### Fixed
- ...'

echo "Asking Claude to draft the changelog..."
response=$(printf '%s' "$context" | claude -p "$prompt")

if [ -z "$response" ]; then
  echo "fatal: claude returned an empty response"
  exit 1
fi

# --- Parse Claude's response -------------------------------------------------

bump=$(printf '%s\n' "$response" | sed -n 's/^BUMP:[[:space:]]*//p' | head -1 | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
reason=$(printf '%s\n' "$response" | sed -n 's/^REASON:[[:space:]]*//p' | head -1)
body=$(printf '%s\n' "$response" | awk 'f{print} /^---[[:space:]]*$/{f=1}')

# Fallback if Claude did not emit the --- separator
if [ -z "$body" ]; then
  body=$(printf '%s\n' "$response" | grep -vE '^(BUMP|REASON):[[:space:]]*')
fi
# Drop leading blank lines from the body
body=$(printf '%s\n' "$body" | sed -e '/./,$!d')

if [ -z "$body" ]; then
  echo "fatal: could not extract a changelog body from Claude's response"
  exit 1
fi

# --- Compute the candidate next versions -------------------------------------

IFS='.' read -r vmaj vmin vpat <<< "$CURRENT_VERSION"
vmaj=${vmaj:-0}; vmin=${vmin:-0}; vpat=${vpat:-0}

PATCH_VERSION="$vmaj.$vmin.$((vpat + 1))"
MINOR_VERSION="$vmaj.$((vmin + 1)).0"

case "$bump" in
  patch) NEXT_VERSION="$PATCH_VERSION" ;;
  minor) NEXT_VERSION="$MINOR_VERSION" ;;
  *) echo "warning: unexpected bump '$bump' from Claude — defaulting to minor"
     bump="minor"; NEXT_VERSION="$MINOR_VERSION" ;;
esac

TODAY=$(date +%Y-%m-%d)

echo ""
echo "Suggested bump: $bump"
if [ "$bump" = "patch" ]; then
  echo "  patch → $PATCH_VERSION   (suggested)"
  echo "  minor → $MINOR_VERSION"
else
  echo "  patch → $PATCH_VERSION"
  echo "  minor → $MINOR_VERSION   (suggested)"
fi
[ -n "$reason" ] && echo "Reason: $reason"
echo ""
echo "The version in the editor's '## [...]' header decides the release — change it"
echo "to the other candidate (or anything) to override the suggested bump."
echo ""

# --- Let the user confirm / edit the entry -----------------------------------

tmpfile=$(mktemp /tmp/git-changelog.XXXXXX)
trap 'rm -f "$tmpfile"' EXIT

{
  printf '## [%s] - %s\n' "$NEXT_VERSION" "$TODAY"
  printf '%s\n' "$body"
} > "$tmpfile"

editor=$(git var GIT_EDITOR 2>/dev/null)
[ -z "$editor" ] && editor="${VISUAL:-${EDITOR:-vi}}"
echo "Opening editor — adjust the version/date and entries, save to continue (empty = abort)."
eval "$editor \"$tmpfile\""

edited=$(cat "$tmpfile")
if [ -z "$(printf '%s' "$edited" | tr -d '[:space:]')" ]; then
  echo "fatal: empty changelog entry — aborting"
  exit 1
fi

# Final version comes from the edited header line, so manual edits are honoured
FINAL_VERSION=$(printf '%s\n' "$edited" | sed -n 's/^##[[:space:]]*\[\([^]]*\)\].*/\1/p' | head -1)

# --- Release pre-checks (before touching anything) ---------------------------

if [ "$RELEASE" -eq 1 ]; then
  if [ -z "$FINAL_VERSION" ]; then
    echo "fatal: could not find a '## [version] - date' header in the entry — cannot tag"
    exit 1
  fi

  TAG="${TAG_PREFIX}${FINAL_VERSION}"

  if git rev-parse -q --verify "refs/tags/$TAG" > /dev/null; then
    echo "fatal: tag $TAG already exists"
    exit 1
  fi

  BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
  if [ -z "$BRANCH" ]; then
    echo "fatal: not on a branch (detached HEAD) — cannot release"
    exit 1
  fi

  # Bundle working-tree changes only when we are in working mode AND there is
  # something uncommitted; otherwise the release commit is CHANGELOG-only.
  BUNDLE=0
  [ "$WORKING" -eq 1 ] && [ "$HAS_UNCOMMITTED" -eq 1 ] && BUNDLE=1

  if [ "$BUNDLE" -eq 1 ]; then
    COMMIT_SCOPE="all working-tree changes + CHANGELOG.md (bundled)"
  else
    COMMIT_SCOPE="CHANGELOG.md only"
  fi

  # Decide how the release commit will be messaged.
  if [ -n "$COMMIT_MSG" ]; then
    MSG_PLAN="\"$COMMIT_MSG\""
  elif [ "$BUNDLE" -eq 1 ] && [ -n "$GIT_COMMIT_MSG" ]; then
    MSG_PLAN="generated by git-commit-msg (opens an editor to confirm/edit)"
  else
    MSG_PLAN="\"Release $FINAL_VERSION\""
  fi

  if [ "$ASSUME_YES" -eq 0 ]; then
    echo ""
    echo "About to release:"
    echo "  version : $FINAL_VERSION"
    echo "  tag     : $TAG"
    echo "  branch  : $BRANCH"
    echo "  commit  : $COMMIT_SCOPE"
    echo "  message : $MSG_PLAN"
    if [ "$PUSH" -eq 1 ]; then
      echo "  push    : origin $BRANCH + $TAG"
    else
      echo "  push    : (skipped, --no-push)"
    fi
    if [ "$BUNDLE" -eq 1 ]; then
      echo "  files to be committed (the CHANGELOG.md update is added on top):"
      git -c color.status=always status --short | sed 's/^/    /'
    fi
    read -r -p "Proceed? [y/N] " ans
    case "$ans" in
      y|Y|yes|YES) ;;
      *) echo "Aborted — no changes made."; exit 0 ;;
    esac
  fi
fi

# --- Insert the entry into the changelog -------------------------------------

# Write the final entry (trim trailing blank lines) to a file for awk/tag use
entryfile=$(mktemp /tmp/git-changelog-entry.XXXXXX)
trap 'rm -f "$tmpfile" "$entryfile"' EXIT
printf '%s\n' "$edited" | sed -e :a -e '/^\s*$/{$d;N;ba}' > "$entryfile"

if [ ! -f "$CHANGELOG_FILE" ]; then
  {
    printf '# Changelog\n'
    printf 'All notable changes to this project will be documented in this file.\n\n'
    printf 'The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),\n'
    printf 'and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).\n\n'
    cat "$entryfile"
    printf '\n'
  } > "$CHANGELOG_FILE"
  echo "Created $CHANGELOG_FILE with the new entry."
elif grep -q '^## \[' "$CHANGELOG_FILE"; then
  newfile=$(mktemp /tmp/git-changelog-new.XXXXXX)
  awk -v entryfile="$entryfile" '
    /^## \[/ && !done {
      if (prev != "") print ""
      while ((getline line < entryfile) > 0) print line
      print ""
      done = 1
    }
    { print; prev = $0 }
  ' "$CHANGELOG_FILE" > "$newfile"
  cat "$newfile" > "$CHANGELOG_FILE"
  rm -f "$newfile"
  echo "Inserted entry into $CHANGELOG_FILE."
else
  # No existing entries — append after the preamble
  printf '\n' >> "$CHANGELOG_FILE"
  cat "$entryfile" >> "$CHANGELOG_FILE"
  printf '\n' >> "$CHANGELOG_FILE"
  echo "Appended entry to $CHANGELOG_FILE."
fi

# --- Release: commit, tag, push ----------------------------------------------

if [ "$RELEASE" -eq 1 ]; then
  if [ "$BUNDLE" -eq 1 ]; then
    echo "Committing all working-tree changes + $CHANGELOG_FILE..."
    git add -A || { echo "fatal: failed to stage changes"; exit 1; }
    if [ -n "$COMMIT_MSG" ]; then
      git commit -m "$COMMIT_MSG" || { echo "fatal: commit failed"; exit 1; }
    elif [ -n "$GIT_COMMIT_MSG" ]; then
      echo "Generating commit message via git-commit-msg..."
      "$GIT_COMMIT_MSG" || { echo "fatal: commit aborted — release stopped (changes staged but not committed)"; exit 1; }
      if ! git diff --cached --quiet; then
        echo "fatal: commit did not complete (changes still staged) — release stopped"
        exit 1
      fi
    else
      git commit -m "Release $FINAL_VERSION" || { echo "fatal: commit failed"; exit 1; }
    fi
  else
    echo "Committing $CHANGELOG_FILE..."
    git add "$CHANGELOG_FILE" || { echo "fatal: failed to stage $CHANGELOG_FILE"; exit 1; }
    git commit -m "${COMMIT_MSG:-Release $FINAL_VERSION}" -- "$CHANGELOG_FILE" || { echo "fatal: commit failed"; exit 1; }
  fi

  echo "Creating tag $TAG..."
  git tag -a "$TAG" -F "$entryfile" || { echo "fatal: failed to create tag $TAG"; exit 1; }

  if [ "$PUSH" -eq 1 ]; then
    echo "Pushing $BRANCH to origin..."
    git push origin "$BRANCH" || { echo "fatal: failed to push $BRANCH"; exit 1; }
    echo "Pushing tag $TAG to origin..."
    git push origin "$TAG" || { echo "fatal: failed to push tag $TAG"; exit 1; }
    echo "Released $TAG and pushed to origin."
  else
    echo "Committed and tagged $TAG locally (not pushed)."
  fi
elif [ "$WORKING" -eq 1 ] && [ "$HAS_UNCOMMITTED" -eq 1 ]; then
  echo "Done. $CHANGELOG_FILE updated — commit it together with your changes, then tag/push."
else
  echo "Done. Review $CHANGELOG_FILE, then commit and tag when ready (or re-run with --release)."
fi
